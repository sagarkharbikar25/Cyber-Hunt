# ─── Supabase ────────────────────────────────────────────────────────────────
# The @supabase/supabase-js SDK connects via HTTPS REST, not raw TCP.
# No port configuration needed here — pooling is handled by Supabase's
# PostgREST layer automatically.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: NEVER expose this on the client side
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used to sign both team JWTs and the admin JWT
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSPHRASE=TECHALFA_ADMIN_2026

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ─── Upstash Redis (caching + rate limiting) ──────────────────────────────────
# Get these from https://console.upstash.com → Create Database → REST API
# The free tier (10k requests/day) is enough for a CTF event.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── Cache TTL tuning (seconds) ───────────────────────────────────────────────
# Raise these during peak load to reduce DB hits further.
CACHE_TTL_LEADERBOARD=10
CACHE_TTL_DASHBOARD=15

# ─── Rate limit tuning ────────────────────────────────────────────────────────
# Loosen during the initial login rush if needed.
RATE_LOGIN_MAX=10        # requests per window per IP
RATE_LOGIN_WINDOW_S=60
RATE_SUBMIT_MAX=5        # submissions per window per team
RATE_SUBMIT_WINDOW_S=60
RATE_HINT_MAX=5          # hint requests per window per team
RATE_HINT_WINDOW_S=60
