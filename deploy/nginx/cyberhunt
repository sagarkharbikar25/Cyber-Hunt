# Nginx server block for CyberHunt
# Save under /etc/nginx/sites-available/cyberhunt on the VPS and symlink to sites-enabled
# Replace yourdomain.com with your actual domain and ensure upstream port matches PM2/Next (default 3000)

server {
  listen 80;
  server_name yourdomain.com www.yourdomain.com;

  client_max_body_size 20M;

  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Optional: serve static assets directly
  location /_next/ {
    proxy_pass http://127.0.0.1:3000;
  }
}
