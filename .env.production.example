# Copy to .env.production and fill values. Keep this file out of version control.
NODE_ENV=production

# Upstash Redis (enable cache + rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase (database + storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# If server-only DB operations require elevated privileges, set SERVICE_ROLE_KEY (keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# JWT / auth
NEXTAUTH_SECRET=
JWT_SECRET=

# Mail / third-party keys
RESEND_API_KEY=

# Tuning
RATE_SUBMIT_MAX=5
RATE_SUBMIT_WINDOW_S=60
CACHE_TTL_LEADERBOARD=10
CACHE_TTL_DASHBOARD=15

# Any other envs your app uses (check src/lib/*.ts)
